# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-2
S3_BUCKET=
S3_REGION=ap-southeast-2
S3_PREFIX=xero-pipeline

# Xero OAuth 2.0
# Run `python -m xero_pipeline_dagster.auth` once to generate XERO_REFRESH_TOKEN
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REFRESH_TOKEN=
# Optional: store refresh token in SSM instead of local file
XERO_TOKEN_SSM_PATH=/xero-pipeline/refresh-token

# Stripe
STRIPE_API_KEY=sk_live_

# Postgres (RDS)
RDS_PG_HOST=
RDS_PG_PORT=5432
RDS_PG_DATABASE=xero_pipeline
RDS_PG_USER=
RDS_PG_PASSWORD=

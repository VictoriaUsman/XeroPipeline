[0m14:14:41.600067 [debug] [Thread-3 (]: Using postgres connection "model.xero_dbt.gold_stripe_movement"
[0m14:14:41.600256 [debug] [Thread-3 (]: On model.xero_dbt.gold_stripe_movement: /* {"app": "dbt", "dbt_version": "1.11.3", "profile_name": "xero", "target_name": "smoke", "node_id": "model.xero_dbt.gold_stripe_movement"} */

  create view "xero_smoke"."public_gold"."gold_stripe_movement__dbt_tmp"
    
    
  as (
    

-- WTD Stripe activity broken down by reporting category
WITH week_start AS (
    SELECT DATE_TRUNC('week', CURRENT_DATE)::DATE AS wk
)

SELECT
    bt.reporting_category,
    bt.currency,
    COUNT(*)            AS transaction_count,
    SUM(bt.amount)      AS gross_amount,
    SUM(bt.fee)         AS total_fees,
    SUM(bt.net)         AS net_amount,
    MIN(bt.created)     AS earliest,
    MAX(bt.created)     AS latest
FROM "xero_smoke"."public_bronze"."bronze_stripe_balance_transactions" bt
CROSS JOIN week_start w
WHERE bt.created::DATE >= w.wk
GROUP BY 1, 2
ORDER BY ABS(SUM(bt.net)) DESC
  );
